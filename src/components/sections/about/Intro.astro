---
// components
import Container from "../../elements/Container.astro";
import ImageContainer from "../../elements/ImageContainer.astro";
import LanguageToggle from "../../elements/LanguageToggle.astro";

// assets
import about from "../../../assets/images/about.jpg";
import stoastage from "../../../assets/images/stoastage.jpg";
import stoabar from "../../../assets/images/stoabar.jpg";

import { Image } from "astro:assets";
---

<Container variant={'xl'} class="flex flex-col py-2 !gap-0">

    <!-- Nav -->
    <nav class="flex flex-wrap gap-4 md:gap-8 justify-center md:justify-start shrink-0 items-center">
        <a href="/" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.home">Home</a>
        <a href="/works" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.posters">Posters</a>
        <a href="/about" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.about">About</a>
        <LanguageToggle />
    </nav>

    <!-- Main content: two columns on desktop -->
    <div class="flex flex-col md:flex-row flex-1 min-h-0 gap-6 md:gap-10 lg:gap-16 mt-6 md:mt-0">

        <!-- Left column: Rat logo -->
        <div class="md:w-2/5 flex items-center justify-center shrink-0">
            <div class="w-full max-w-[14rem] md:max-w-[18rem] lg:max-w-[22rem]">
                <ImageContainer src={about} alt="ΣΤΟΑ60 logo — rat carrying the venue name" />
            </div>
        </div>

        <!-- Right column: Title + text (scrollable on desktop for long EN text) -->
        <div class="md:w-3/5 flex flex-col justify-center gap-4 lg:gap-6 md:overflow-y-auto md:py-4">
            <!-- Title -->
            <h1 class="font-grunge uppercase text-base-900 tracking-tight leading-none text-64 md:text-80 lg:text-128" data-i18n="about.title">about</h1>

            <!-- Intro line -->
            <p class="text-base-900 font-bahnschrift font-normal text-20 lg:text-24 leading-relaxed" data-i18n="about.intro">
                Η Στοα 60 είναι μία ομάδα που διοργανώνει συναυλίες σχεδόν εβδομαδιαία από το 2015, σε ένα υπόγειο στο κέντρο του Ηρακλείου Κρήτης.
            </p>

            <!-- Manifesto -->
            <p class="text-base-900 font-bahnschrift font-bold text-14 lg:text-18 leading-relaxed" data-i18n="about.manifesto">
                Φιλοξενούμε σχήματα της ανεξάρτητης μουσικής σκηνής και επιλέγουμε να λειτουργούμε ανταγωνιστικά στη λογική του κέρδους και της σύγχρονης βιομηχανίας του θεάματος. Προσπαθούμε να φτιάχνουμε ένα περιβάλλον ισότητας, χωρίς διαχωρισμούς μεταξύ μουσικών-κοινού-διοργανωτών, χωρίς περιορισμούς σε μουσικά είδη και ενάντια σε σεξιστικές, φασιστικές και ρατσιστικές συμπεριφορές. Βλέπουμε την μουσική σαν ένα μέσο έκφρασης, διάδοσης ιδεών και αφορμή κοινωνικοποίησης, αλληλεπίδρασης και συνδιαμόρφωσης. Το κουτί ενίσχυσης και η ελεύθερη ενίσχυση στο Bar καλύπτουν τα λειτουργικά έξοδα του χώρου και του εξοπλισμού καθώς και τα μεταφορικά έξοδα για να ταξιδεύουν σχήματα από όλη την Ελλάδα.
            </p>
        </div>

    </div>

    <!-- Photo strip -->
    <div class="grid grid-cols-2 gap-4 mt-8 md:mt-12">
        <Image src={stoastage} alt="Stoa 60 stage" class="w-full h-64 md:h-80 object-cover" />
        <Image src={stoabar} alt="Stoa 60 bar" class="w-full h-64 md:h-80 object-cover" />
    </div>

</Container>
---
// layout
import Layout from "../../layouts/Layout.astro";

// components
import Heading from "../../components/elements/Heading.astro";
import Container from "../../components/elements/Container.astro";
import LanguageToggle from "../../components/elements/LanguageToggle.astro";
import { Image } from "astro:assets";

// database
import { events } from "../../data/events.ts";

// Load all poster images into a path→ImageMetadata lookup
const posterGlob = import.meta.glob<{ default: ImageMetadata }>(
    "../../assets/images/posters/**/*.{jpg,jpeg,png}",
    { eager: true }
);
const posterMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(posterGlob)) {
    const key = path.replace("../../assets/images/posters/", "");
    posterMap[key] = mod.default;
}

interface PosterEntry {
    image: ImageMetadata;
    date: string;
    rawTitle: string;
    location: string;
    organiser: string[];
    eventType: string;
    bands: string[];
}

function formatDate(dateStr: string): string {
    const [y, m, d] = dateStr.split("-");
    return `${d}.${m}.${y}`;
}

function dateToSeason(dateStr: string): string {
    const [y, m] = dateStr.split("-").map(Number);
    return m >= 9 ? `${y}-${y + 1}` : `${y - 1}-${y}`;
}

// Build full poster list from database (events already newest-first)
const allPosters: PosterEntry[] = events
    .filter(e => e.poster && posterMap[e.poster])
    .map(e => ({
        image:     posterMap[e.poster],
        date:      e.date,
        rawTitle:  e.rawTitle,
        location:  e.location,
        organiser: e.organiser,
        eventType: e.eventType,
        bands:     e.bands,
    }));

// Unique sorted band list for autocomplete (exclude placeholder "TBA")
const allBands: string[] = [...new Set(
    allPosters.flatMap(p => p.bands).filter(b => b && b !== "TBA")
)].sort((a, b) => a.localeCompare(b, "el"));

// Season grouping
const seasonMap: Record<string, PosterEntry[]> = {};
for (const p of allPosters) {
    const s = dateToSeason(p.date);
    (seasonMap[s] ??= []).push(p);
}
const seasons = Object.keys(seasonMap)
    .filter(y => y !== "2026-2027")
    .sort((a, b) => b.localeCompare(a))
    .map(year => ({ year, posters: seasonMap[year] }));

// Location sections
const undergroundPosters = allPosters.filter(p => p.location === "underground");

const locationDisplayNames: Record<string, { el: string; en: string; key: string }> = {
    georgiadis:   { el: "Πάρκο Γεωργιάδη", en: "Georgiadis Park", key: "loc.georgiadis"   },
    karabolas:    { el: "Καραβολάς",        en: "Karabolas",       key: "loc.karabolas"    },
    voutes:       { el: "Βούτες",           en: "Voutes",          key: "loc.voutes"       },
    xenia:        { el: "Ξένια",            en: "Xenia",           key: "loc.xenia"        },
    evangelismos: { el: "Ευαγγελισμός",     en: "Evangelismos",    key: "loc.evangelismos" },
    walls:        { el: "Τείχη",            en: "Walls",           key: "loc.walls"        },
};

const venueOrder = ["georgiadis", "karabolas", "voutes", "xenia"];
const venues = venueOrder
    .map(loc => ({
        key:     loc,
        el:      locationDisplayNames[loc].el,
        en:      locationDisplayNames[loc].en,
        i18nKey: locationDisplayNames[loc].key,
        posters: allPosters.filter(p => p.location === loc),
    }))
    .filter(v => v.posters.length > 0);

// Special sections
const ba2037Posters     = allPosters.filter(p => p.organiser.includes("ba2037"));
const rastapankPosters  = allPosters.filter(p => p.organiser.includes("rastapank"));
const barPosters        = allPosters.filter(p => p.eventType === "Bar");

const festivalKeywords  = ["down tuned", "makrovoutes", "tsurai", "fertility", "voutopia", "el paso"];
const festivalPosters   = allPosters.filter(p =>
    festivalKeywords.some(kw =>
        p.eventType.toLowerCase().includes(kw) ||
        p.rawTitle.toLowerCase().includes(kw)
    )
);

// Georgiadis Park description
const georgiadisIntro = {
    el: "Το πάρκο Γεωργιάδη βρίσκεται στην καρδιά της πόλης και αποτελεί μία ανάσα πρασίνου μέσα στην εμπορική τσιμεντούπολη του κέντρου. Υπήρξε ένας αναγκαίος χώρος πολιτιστικής ζωής φιλοξενώντας ένα τεράστιο εύρος εκδηλώσεων από πολλούς και ετερόκλητους φορείς της πόλης του Ηρακλείου.",
    en: "Georgiadis Park lies at the heart of the city, a rare patch of green breathing room amid the commercial concrete maze of the city centre. For years it has served as a vital hub of cultural life, opening its grounds to an eclectic mix of events organized by the many and varied groups that make up the fabric of Heraklion.",
};
const georgiadisBody = {
    el: `Το 2017 ο δήμος ανακοινώνει το σχέδιο μίας τελείως πρόχειρης και επικύνδινης ανάπλασης. Ο αγώνας για τον βασικότερο πνεύμονα της πόλης γεννάει τις Φυλές του Πάρκου, μία ανοιχτή συνέλευση που αναλαμβάνει τη προστασία του, τη νομική υπεράσπιση και τη διαχείριση του. Το διάστημα που περνάει η κινητοποίηση είναι έντονη, συμβαίνουν μεγάλες πορείες και αυτό φέρνει μία τρομερή δυναμική στις εκδηλώσεις, αλλά και στην γενικότερη οικειοποίηση, διαμόρφωση και αντίληψη του χώρου αυτού ως κοινό. Η ομάδα της στοάς60 έκανε την παρθενική της εκδήλωση στο πάρκο τον μακρινό Οκτώβρη του 2015, πριν καν στηθεί το υπόγειο στη Καλοκαιρινού και κατά τη διάρκεια της κινητοποίησης του 2018 ήταν πάλι εκεί και έστησε μια σειρά προβολές και αξιομνημόνευτα λάϊβ.

Τον Οκτώβρη του 2019, μετά από το πιο όμορφο καλοκαίρι του Πάρκου, με τη δικαστική διαμάχη να τραβάει, ο δήμος, ο εργολάβος μαζί με τα ΜΑΤ αποφασίζουν να προχωρήσουν με τα έργα της ανάπλασης. Την ημέρα εκείνη η ευρύτερη κοινότητα που ενώθηκε γύρω από αυτό τον αγώνα, θα κοντραριστεί σώμα με σώμα με τους αστυνομικούς, θα κερδίσει τη συγκεκριμένη μάχη, αλλά δεν θα αντέξει στην καθημερινότητα της επιβολής της αστυνομιας και των εκσαφέων τους. Το πάρκο περυτιλίγεται με λαμαρίνες και θα περάσουν 2-3 χρόνια και κάμποση καραντίνα μέχρι να το ξαναδούμε. Όταν αυτό πλέον άνοιξε, με ένα τελείως διαφορετικό καθεστώς. Στο βασικό χώρο που φιλοξενούνταν λάϊβ έχει πλέον τις τεράστιες ομπρέλες του καφέ που εκμεταλλεύεται ιδιώτης, υπάρχει ένας σεκιουριτάς μόνιμα στο χώρο και το καθεστώς άδειας καθορίζεται από την αναπαραγωγική σεζόν διαφόρων πτηνών.`,
    en: `In 2017, the municipality announced plans for a hasty and ill-conceived renovation. The struggle to defend the city's primary green lung gave birth to the Φυλές του Πάρκου (Tribes of the Park) — an open assembly that took on its protection, its legal defence, and its management. Large marches took place, bringing tremendous momentum to the events held there, as well as to the broader appropriation, shaping, and understanding of this space as a common. Stoa60 held its very first event there back in 2015, even before the underground venue on Kalokerinou Street had been set up, and during the mobilization of 2018 they were there again, staging a series of screenings and memorable live shows.

In October 2019, following the most active summer the park had seen in terms of cultural life, with the legal battle still dragging on, the municipality, the contractor, and the riot police decided to push ahead with the renovation works. On that day, the wider community that had united around this struggle clashed with the police, won that particular battle — but could not hold out against the daily pressure of police enforcement and their excavators. The park was wrapped in corrugated iron sheeting, and it would take two to three years and a good stretch of lockdown before we would see it again. When it finally reopened, it did so under an entirely different regime. The main space that used to host live music now holds the massive umbrellas of a café operated by a private individual; there is a security guard permanently stationed on the premises; and the conditions for obtaining a permit are now dictated by the breeding season of various bird species.`,
};

// Xenia description
const xeniaText = {
    el: `Μερικά χρόνια μετά την ανάπλαση της παραλιακής του Ηρακλείου και το κλείσιμο του ξενοδοχείου από του οποίου πήρε το όνομα η συγκεκριμένη τοποθεσία, μια μικρή απλωσιά εμφανίστηκε μόλις 10 λεπτά από το κέντρο της πόλης. Το παραθαλλάσιο αμφιθεατρικό του "ξενία" έγινε για μια 5ετία τόπος συνάντησης μιας μεγάλης κοινότητας. Τα πάρτυ στις αρχές και τα τέλη του Καλοκαιριού από το 2016 μέχρι το 2018 είχαν γίνει εβδομαδιαία. Αυτοργανωμένες ομάδες της πόλης, φοιτητικοί σύλλογοι ή απλά παρέες που βολόδερναν κάθε βράδυ εκεί, οικειοποιήθηκαν το χώρο και όλο αυτό άρχισε σιγά σιγά να "ξενίζει". Τα τοπικά μίντια δημιούργησαν το κλίμα, διάφοροι κάτοικοι ξεκίνησαν τις καταγγελίες και το 2018 ο κύκλος του Ξενία έκλεισε.`,
    en: `A few years after the renovation of Heraklion's waterfront and the shut-down of the hotel that gave this particular spot its name, a small open expanse appeared just 10 minutes from the city centre. The seaside amphitheatre known as "Xenia" spent the better part of five years as a meeting point for a large and sprawling community. What began as parties at the bookends of summer gradually turned into a weekly ritual, running from 2016 through to 2018. Self-organized city collectives, student associations, and loose groups of people who simply found themselves there night after night made the space their own — and it was precisely this slow, organic takeover that started to rub certain people the wrong way. Local media worked to build a narrative around it, residents began lodging formal complaints, and by 2018 the Xenia era had run its course.`,
};

// BA2037 description
const ba2037Intro = {
    el: "Η ΒΑ2037 λειτούργησε από τα τέλη του '18 μέχρι περίπου το 2021, υπήρξε οργανικό κομμάτι της στοάς60 με αρκετά κοινά μέλη και επικεντρωνόταν στον ηλεκτρονικό και πειραματικό ήχο. Ακολουθεί το αυτοπαρουσιαστικό της κείμενο.",
    en: "BA2037 was active from late 2018 until roughly 2022. An integral part of Stoa60 with several shared members, focused on electronic and experimental sound. This is how they introduced themselves back in the day.",
};

const ba2037Quote = {
    el: `Η ομάδα αποτελείται από μουσικούς, μουσικόφιλους και Djs με κοινή επιθυμία να βρούμε χώρο και χρόνο στο Ηράκλειο να ακούσουμε /παίξουμε / χορέψουμε / αναπαράγουμε τη μουσική που γουστάρουμε. Κινούμαστε στον ωκεανό της ηλεκτρονικής και πειραματικής μουσικής και θα θελαμε να προσεγγίσουμε τα βάθη της.

Επιδιώκουμε να δώσουμε χώρο σε μουσική η οποία δεν ακούγεται σε μέρη που συχνά διασκεδάζουμε, δεν προωθείται από την κυρίαρχη μουσική βιομηχανία και πολλές φορές ειναι αποτελεσμα αυτοσχεδιασμού και πειραματισμού. Σκοπεύουμε στην ανάδειξη και ανακάλυψη διαφόρων και διαφορετικών αισθήσεων, αισθητικών, τρόπων απόλαυσης και επικοινωνίας, τρόπων δημιουργίας και έκφρασης γύρω από την ηλεκτρονική και πειραματική μουσική.

Στόχος μας είναι η διοργάνωση μουσικών εκδηλώσεων και η συνεργασία με άλλους ανάλογους χώρους και πρωτοβουλίες στο Ηρακλειο με κοινές επιδιώξεις, τρόπους λειτουργίας και ύπαρξης.

Υπάρχουμε ανεξάρτητα και αντιεραρχικά, χωρίς χορηγούς, έξω από μαγαζιά, χωρίς να αποσκοπούμε με κανένα τρόπο σε προσωπικό οικονομικό κέρδος, ουτε εμείς αλλά ούτε και οι καλλιτέχνες που φιλοξενούνται στα live. Σε όλες τις εκδηλώσεις που διοργανώνονται η είσοδος είναι ελεύθερη, καθως δεν θελουμε να αποκλείσουμε κανέναν και καμία. Παρόλα αυτά θεωρούμε την ενίσχυση μέσω του κουτιού απαραίτητη για την κάλυψη των λειτουργικών εξόδων, τοσο της ομάδας όσο και των χώρων που ενίοτε μας φιλοξενούν (Στοα 60) καθώς και για την συνέχιση και αναβάθμιση του όλου εγχειρήματος.

Έχουμε ανάγκη να διαμορφώσουμε εκείνες τις συνθήκες μέσα στις οποίες κάθε άτομο θα μπορέσει να απολαύσει την μουσική, να εκφραστεί όπως νιώθει και κάθε σώμα θα έχει ίση ευκαιρία να διεκδικήσει το χώρο ανάμεσα στα άλλα χωρίς να περιορίζεται και να περιορίζει. Θα θέλαμε οι συναντήσεις που διοργανώνουμε εμείς να αποτελούν ασφαλείς χώρους για όλα τα άτομα και έτσι ομοφοβικές, εξουσιαστικές, τρανσφοβικές, σεξιστικές, ρατσιστικές και άλλες συμπεριφορές έκφρασης μίσους που επιβάλλονται βίαια πάνω σε αυτονόητες ελευθερίες, δεν είναι ανεκτές.

See you on the dancefloor`,
    en: `The project consists of people that are interested in music, musicians and Djs with common desire to find space and time in order to listen/play/dance/(re) produce the music that we enjoy. We find ourselves somewhere in the ocean of electronic and experimental music and we would like to access the very depths of it.

We want to create room to music that does not exist to places that we usually get entertained, music that is not being promoted by the main music industry and music that, from time to time, is a result of our improvisation and experimentation. We are targeting to the prominence and discovery of different kinds of consciousness, feelings, ways of joy and communication, ways of creation and expression that are being surrounded by the electronic and experimental music.

Our target is the organization of electronic music events and the cooperation with other equivalent groups, teams and initiatives that exists in Heraklion which serves the same goals, modes of operation and existence.

We exist independently and non-hierarchically, with no sponsors, outside of stores, bars, clubs, with no intention to gain in any way any personal financial profit, neither us nor the artists that are coming to perform. To all of our events there is a free entrance in order for nobody to be excluded. Nonetheless, we believe that the enhancement through the box is necessary to cover the functional expenses of the team and groups/teams/projects that we are cooperating (Stoa60) as well as for the continuation of the whole project.

We feel the need to create these circumstances where each person will be able to enjoy the music, to express theirself as they feel and every human body will have equal opportunities to claim its own space between the space of the others without creating constraints and without being constrained. The meetings that we organise, we imagine them as meetings where the place is safe for each and every person, thus, homophobic, authoritative, transphobic, sexistic and other behaviors of racist nature are not going to be accepted/tolerated.

See you on the dancefloor!`,
};
---

<Layout title="Posters" footerInnerClass="md:pl-44" tileBgOnMobile={true} mobileBgWide={true}>
    <Container variant={'xl'} class="flex flex-col !gap-0 items-start">

        <!-- Title + Nav + Category title -->
        <div class="w-full pt-2 pb-1 md:pl-44">
            <div class="flex flex-col md:flex-row md:gap-8 md:items-baseline items-center gap-1 md:border-b border-base-900/30 md:pb-0.5">
                <Heading tagName="h1" tagSize="h2" class="title-flicker" data-i18n="works.title">Posters</Heading>
                <nav class="flex flex-wrap gap-4 md:gap-8 items-center">
                    <a href="/" class="text-base-900 font-grunge text-2xl md:text-3xl hover:text-base-700" data-i18n="nav.home">Home</a>
                    <a href="/about" class="text-base-900 font-grunge text-2xl md:text-3xl hover:text-base-700" data-i18n="nav.about">About</a>
                    <LanguageToggle />
                </nav>
                <!-- Band search — lives in the navbar row -->
                <div id="search-container" class="relative w-2/3 md:w-40 flex-shrink-0">
                    <div class="relative flex items-center">
                        <input
                            type="search"
                            id="band-search"
                            placeholder="Search bands…"
                            class="w-full font-bahnschrift text-sm bg-transparent border border-base-900/25 px-3 py-1.5 text-base-900 placeholder:text-base-900/30 focus:outline-none focus:border-base-900/55 pr-7"
                            autocomplete="off"
                            spellcheck="false"
                            aria-label="Search bands"
                            aria-autocomplete="list"
                            aria-controls="search-autocomplete"
                            aria-haspopup="listbox"
                        />
                        <button
                            id="search-clear"
                            type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-base-900/30 hover:text-base-900/70 hidden leading-none select-none"
                            aria-label="Clear search"
                            style="font-size:1.25rem;line-height:1"
                        >×</button>
                    </div>
                    <ul
                        id="search-autocomplete"
                        role="listbox"
                        class="absolute top-full left-0 right-0 z-50 hidden border border-base-900/25 border-t-0 max-h-64 overflow-y-auto"
                        style="background: oklch(16% 0.002 106);"
                    ></ul>
                </div>
                <h2 id="category-title" class="hidden md:block font-bahnschrift font-bold text-base-900/40 text-3xl tracking-wide uppercase select-none ml-auto"></h2>
            </div>
        </div>

        <!-- Two-column layout: sidebar tabs | main content -->
        <div id="main-layout" class="w-full flex flex-col md:flex-row gap-0 pt-2">

            <!-- Sidebar: horizontal on mobile, vertical on desktop -->
            <div id="cat-sidebar" class="flex flex-col md:flex-col md:shrink-0 md:w-36 md:border-r md:border-base-900/20 md:pr-4 gap-0.5 border-base-900/20 pb-6 mb-6 md:border-b-0 md:pb-0 md:mb-0">

                <!-- Σεζόν group -->
                <span class="font-bahnschrift font-bold uppercase text-xs tracking-widest text-base-900/30 px-2 pb-1 md:border-b border-base-900/15 select-none block text-center md:text-left" data-i18n="loc.seasons">Σεζόν</span>

                <div class="flex flex-row flex-wrap md:flex-col gap-2 md:gap-0.5 justify-center md:justify-start">
                    {seasons.map(s => (
                        <button
                            class="category-tab font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                            data-target={`section-${s.year}`}
                        >{s.year}</button>
                    ))}
                </div>

                <!-- Τοποθεσία group -->
                <div class="sidebar-divider border-t border-base-900/20 my-2" />
                <span class="font-bahnschrift font-bold uppercase text-xs tracking-widest text-base-900/30 px-2 pb-1 md:border-b border-base-900/15 select-none block text-center md:text-left" data-i18n="loc.locations">Τοποθεσία</span>

                <div class="flex flex-row flex-wrap md:flex-col gap-2 md:gap-0.5 justify-center md:justify-start">
                    <button
                        class="category-tab font-bahnschrift font-bold uppercase text-sm md:text-base text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                        data-target="section-venue-underground"
                        data-i18n="loc.underground"
                    >Underground</button>

                    {venues.map(v => (
                        <button
                            class="category-tab font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                            data-target={`section-venue-${v.key}`}
                            data-i18n={v.i18nKey}
                        >{v.el}</button>
                    ))}
                </div>

                <!-- Festivals / BA2037 / Bar -->
                <div class="sidebar-divider border-t border-base-900/20 my-2" />
                <div class="flex flex-row md:flex-col gap-2 md:gap-0.5 justify-center md:justify-start">
                    {festivalPosters.length > 0 && (
                        <button
                            class="category-tab font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                            data-target="section-festivals"
                            data-i18n="loc.festivals"
                        >Φεστιβάλ</button>
                    )}
                    {ba2037Posters.length > 0 && (
                        <button
                            class="category-tab font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                            data-target="section-ba2037"
                        >BA2037</button>
                    )}
                    {rastapankPosters.length > 0 && (
                        <button
                            class="category-tab font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                            data-target="section-rastapank"
                        >Rastapank</button>
                    )}
                    {barPosters.length > 0 && (
                        <button
                            class="category-tab font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/60 border-l-2 border-transparent select-none"
                            data-target="section-bar"
                            data-i18n="works.bar"
                        >Bar</button>
                    )}
                </div>

                <!-- For Print: desktop only -->
                <div class="sidebar-divider hidden md:block border-t border-base-900/20 my-2" />
                <a
                    href="https://drive.google.com/drive/folders/1nie729Boi20WuEhENw9cHMDtSr02pK-M?usp=sharing"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hidden md:block font-bahnschrift font-bold uppercase text-base md:text-lg text-left px-2 py-1.5 text-base-900/50 border border-dashed border-base-900/20 bg-base-900/10 hover:bg-base-900/25 hover:border-base-900/40 transition-colors leading-tight select-none"
                    data-i18n="works.for_print"
                >Για τύπωμα</a>

            </div>

            <!-- Main content: poster grid -->
            <div id="main-content" class="flex-1 md:pl-8 min-w-0 flex flex-col gap-2">

                <!-- Search results section -->
                <div id="section-search" class="poster-section hidden">
                    <div id="search-grid" class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end"></div>
                    <p id="search-empty" class="hidden font-bahnschrift text-sm text-base-900/40 py-8 text-center">No posters found.</p>
                </div>

                <!-- Season sections — location label only, no date -->
                {seasons.map(s => (
                    <div id={`section-${s.year}`} class="poster-section hidden">
                        <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                            {s.posters.map(p => (
                                <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                    {p.location !== "underground" && locationDisplayNames[p.location] && (
                                        <span class="font-bahnschrift text-sm text-base-900/40 mb-2 uppercase tracking-wider text-center order-first" data-i18n={locationDisplayNames[p.location].key}>{locationDisplayNames[p.location].el}</span>
                                    )}
                                    <Image
                                        src={p.image}
                                        alt={p.rawTitle}
                                        class="w-full h-auto object-contain poster-img"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                ))}

                <!-- Underground section -->
                <div id="section-venue-underground" class="poster-section hidden">
                    <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                        {undergroundPosters.map(p => (
                            <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                <span class="font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center">{formatDate(p.date)}</span>
                                <Image
                                    src={p.image}
                                    alt={p.rawTitle}
                                    class="w-full h-auto object-contain poster-img"
                                    loading="lazy"
                                />
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Outdoor venue sections (database-driven) -->
                {venues.map(v => (
                    <div id={`section-venue-${v.key}`} class="poster-section hidden">
                        {/* georgiadis and xenia descriptions hidden for now
                        {v.key === "georgiadis" && (
                            <>
                                <p class="font-bahnschrift text-sm text-base-900/60 leading-relaxed w-full mb-2" data-i18n="georgiadis.intro">{georgiadisIntro.el}</p>
                                <p class="font-bahnschrift text-sm text-base-900/40 leading-relaxed w-full whitespace-pre-line columns-1 md:columns-2 lg:columns-4 gap-6 mb-4" data-i18n="georgiadis.body">{georgiadisBody.el}</p>
                            </>
                        )}
                        {v.key === "xenia" && (
                            <p class="font-bahnschrift text-sm text-base-900/60 leading-relaxed w-full whitespace-pre-line columns-1 md:columns-2 gap-6 mb-4" data-i18n="xenia.text">{xeniaText.el}</p>
                        )}
                        */}
                        <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                            {v.posters.map(p => (
                                <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                    <span class="font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center order-first">{formatDate(p.date)}</span>
                                    <Image
                                        src={p.image}
                                        alt={p.rawTitle}
                                        class="w-full h-auto object-contain poster-img"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                ))}

                <!-- Festivals section -->
                {festivalPosters.length > 0 && (
                    <div id="section-festivals" class="poster-section hidden">
                        <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                            {festivalPosters.map(p => (
                                <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                    <span class="font-bahnschrift text-sm text-base-900/40 mb-1 uppercase tracking-wider text-center order-first">{p.eventType}</span>
                                    <span class="font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center order-first">{formatDate(p.date)}</span>
                                    <Image
                                        src={p.image}
                                        alt={p.rawTitle}
                                        class="w-full h-auto object-contain poster-img"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <!-- BA2037 section -->
                {ba2037Posters.length > 0 && (
                    <div id="section-ba2037" class="poster-section hidden flex flex-col gap-4">
                        <p class="font-bahnschrift text-sm text-base-900/60 leading-relaxed w-full" data-i18n="ba2037.intro">{ba2037Intro.el}</p>
                        <blockquote class="font-bahnschrift text-sm text-base-900/40 leading-relaxed w-full whitespace-pre-line columns-1 md:columns-2 lg:columns-4 gap-6 border-l-2 border-base-900/20 pl-4 italic" data-i18n="ba2037.quote">{ba2037Quote.el}</blockquote>
                        <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                            {ba2037Posters.map(p => (
                                <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                    <span class="font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center">{formatDate(p.date)}</span>
                                    <Image
                                        src={p.image}
                                        alt={p.rawTitle}
                                        class="w-full h-auto object-contain poster-img"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <!-- Rastapank section -->
                {rastapankPosters.length > 0 && (
                    <div id="section-rastapank" class="poster-section hidden">
                        <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                            {rastapankPosters.map(p => (
                                <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                    <span class="font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center">{formatDate(p.date)}</span>
                                    <Image
                                        src={p.image}
                                        alt={p.rawTitle}
                                        class="w-full h-auto object-contain poster-img"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <!-- Bar section -->
                {barPosters.length > 0 && (
                    <div id="section-bar" class="poster-section hidden">
                        <div class="grid lg:grid-cols-4 md:grid-cols-3 grid-cols-2 gap-6 w-full items-end">
                            {barPosters.map(p => (
                                <div class="w-full cursor-pointer poster-thumb flex flex-col items-center" data-bands={JSON.stringify(p.bands)} data-date={p.date} data-location={p.location}>
                                    <span class="font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center">{formatDate(p.date)}</span>
                                    <Image
                                        src={p.image}
                                        alt={p.rawTitle}
                                        class="w-full h-auto object-contain poster-img"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                )}

            </div>
        </div>

    </Container>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 items-center justify-center" style="display:none" role="dialog" aria-modal="true" aria-label="Poster gallery viewer">
        <button id="close-lightbox" class="absolute top-4 right-4 text-white text-4xl font-grunge hover:opacity-70 z-10" aria-label="Close lightbox">&times;</button>
        <button id="prev-lightbox" class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-5xl font-grunge hover:opacity-70 z-10 select-none" aria-label="Previous poster">&#8249;</button>
        <button id="next-lightbox" class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-5xl font-grunge hover:opacity-70 z-10 select-none" aria-label="Next poster">&#8250;</button>
        <img id="lightbox-img" src="" alt="Poster preview" class="max-h-[90vh] max-w-[85vw] object-contain" />
    </div>

    <script id="bands-data" type="application/json" set:html={JSON.stringify(allBands)}></script>

    <style>
        .poster-img {
            transition: opacity 0.3s ease, box-shadow 0.3s ease;
        }

        .poster-thumb:hover .poster-img {
            opacity: 0.9;
            box-shadow:
                0 0 0 1px rgba(255, 255, 255, 0.10),
                0 2px 12px rgba(255, 255, 255, 0.13),
                0 6px 30px rgba(255, 255, 255, 0.16);
        }

        .category-tab {
            position: relative;
            overflow: hidden;
            transition: color 0.25s ease, border-color 0.25s ease;
        }

        .category-tab::before {
            content: '';
            position: absolute;
            inset: 0;
            background: oklch(98% 0.001 106.423 / 7%);
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            pointer-events: none;
        }

        .category-tab:hover::before,
        .category-tab.tab-active::before {
            transform: translateX(0);
        }

        .category-tab::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 2px;
            right: 2px;
            height: 1px;
            background: oklch(98% 0.001 106.423 / 20%);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
            pointer-events: none;
        }

        .category-tab:hover::after { transform: scaleX(1); }

        .category-tab:hover {
            border-left-color: oklch(98% 0.001 106.423 / 50%);
            color: oklch(98% 0.001 106.423 / 80%);
        }

        .category-tab.tab-active {
            border-left-color: oklch(98% 0.001 106.423);
            color: oklch(98% 0.001 106.423);
        }

        .category-tab.tab-active::after {
            transform: scaleX(1);
            background: oklch(98% 0.001 106.423 / 40%);
        }

        @media (max-width: 767px) {
            #cat-sidebar .sidebar-divider {
                width: 50%;
                margin: 0.25rem auto;
            }

            #cat-sidebar .category-tab {
                border: 1px solid oklch(98% 0.001 106.423 / 15%);
                border-left-width: 2px;
            }

            #cat-sidebar .category-tab.tab-active {
                border-color: oklch(98% 0.001 106.423 / 30%);
                border-left-color: oklch(98% 0.001 106.423);
            }
        }

        #band-search::-webkit-search-cancel-button,
        #band-search::-webkit-search-decoration {
            display: none;
        }

        /* :global() required — buttons are created dynamically in JS, no Astro scope attr */
        :global(.search-suggestion) {
            display: block;
            width: 100%;
            text-align: left;
            padding: 0.375rem 0.75rem;
            font-size: 0.8125rem;
            color: oklch(98% 0.001 106.423 / 70%);
            background: transparent;
            border: none;
            cursor: pointer;
            transition: color 0.15s ease, background-color 0.15s ease;
        }

        :global(.search-suggestion:hover),
        :global(.search-suggestion.suggestion-active) {
            color: oklch(98% 0.001 106.423);
            background-color: oklch(98% 0.001 106.423 / 8%);
        }
    </style>

    <script>
        // --- Category tab navigation ---
        const tabs     = document.querySelectorAll<HTMLButtonElement>(".category-tab");
        const sections = document.querySelectorAll<HTMLElement>(".poster-section");

        const categoryTitle = document.getElementById("category-title") as HTMLElement;

        function syncCategoryTitle() {
            const active = document.querySelector<HTMLButtonElement>(".category-tab.tab-active");
            if (categoryTitle && active) {
                categoryTitle.textContent = active.textContent?.trim() || "";
                const isLong = active.dataset.target === "section-venue-georgiadis";
                categoryTitle.classList.toggle("text-3xl", !isLong);
                categoryTitle.classList.toggle("text-xl", isLong);
            }
        }

        function activateTab(btn: HTMLButtonElement) {
            tabs.forEach(b => b.classList.remove("tab-active"));
            sections.forEach(s => s.classList.add("hidden"));
            btn.classList.add("tab-active");
            document.getElementById(btn.dataset.target!)?.classList.remove("hidden");
            syncCategoryTitle();
        }

        document.querySelectorAll("#lang-toggle").forEach(btn => {
            btn.addEventListener("click", () => requestAnimationFrame(syncCategoryTitle));
        });

        tabs.forEach(btn => btn.addEventListener("click", () => activateTab(btn)));

        const firstTab = document.querySelector<HTMLButtonElement>(".category-tab");
        if (firstTab) activateTab(firstTab);

        // --- Lightbox ---
        const lightbox    = document.getElementById("lightbox") as HTMLElement;
        const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
        const closeBtn    = document.getElementById("close-lightbox") as HTMLElement;
        const prevBtn     = document.getElementById("prev-lightbox") as HTMLElement;
        const nextBtn     = document.getElementById("next-lightbox") as HTMLElement;

        let currentSrcs: string[] = [];
        let currentIdx  = 0;

        function getVisibleSrcs(): string[] {
            return Array.from(
                document.querySelectorAll<HTMLImageElement>(".poster-section:not(.hidden) .poster-thumb img")
            ).map(img => img.currentSrc || img.getAttribute("src") || "");
        }

        let lastFocusedElement: HTMLElement | null = null;

        function showLightbox(srcs: string[], idx: number) {
            lastFocusedElement = document.activeElement as HTMLElement;
            currentSrcs = srcs;
            currentIdx  = idx;
            lightboxImg.src = currentSrcs[currentIdx];
            prevBtn.style.opacity = currentIdx > 0 ? "1" : "0.2";
            nextBtn.style.opacity = currentIdx < currentSrcs.length - 1 ? "1" : "0.2";
            lightbox.style.display = "flex";
            closeBtn.focus();
        }

        function hideLightbox() {
            lightbox.style.display = "none";
            lastFocusedElement?.focus();
        }

        // Event delegation — works for both original thumbs and search-result clones
        document.getElementById("main-content")!.addEventListener("click", (e) => {
            const thumb = (e.target as HTMLElement).closest<HTMLElement>(".poster-thumb");
            if (!thumb) return;
            const srcs = getVisibleSrcs();
            const img  = thumb.querySelector("img");
            if (!img) return;
            const src = img.currentSrc || img.getAttribute("src") || "";
            const idx = srcs.indexOf(src);
            showLightbox(srcs, idx !== -1 ? idx : 0);
        });

        prevBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            if (currentIdx > 0) showLightbox(currentSrcs, currentIdx - 1);
        });

        nextBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            if (currentIdx < currentSrcs.length - 1) showLightbox(currentSrcs, currentIdx + 1);
        });

        closeBtn.addEventListener("click", hideLightbox);
        lightbox.addEventListener("click", (e) => { if (e.target === lightbox) hideLightbox(); });

        window.addEventListener("keydown", (e) => {
            if (lightbox.style.display === "none" || !lightbox.style.display) return;
            if (e.key === "Escape") hideLightbox();
            if (e.key === "ArrowLeft"  && currentIdx > 0)                          showLightbox(currentSrcs, currentIdx - 1);
            if (e.key === "ArrowRight" && currentIdx < currentSrcs.length - 1)     showLightbox(currentSrcs, currentIdx + 1);
        });

        // --- Band search & autocomplete ---
        const allBands: string[] = JSON.parse(
            document.getElementById("bands-data")?.textContent ?? "[]"
        );

        const bandSearch      = document.getElementById("band-search")      as HTMLInputElement;
        const autocomplete    = document.getElementById("search-autocomplete") as HTMLUListElement;
        const searchClear     = document.getElementById("search-clear")     as HTMLButtonElement;
        const searchSection   = document.getElementById("section-search")   as HTMLElement;
        const searchGrid      = document.getElementById("search-grid")      as HTMLElement;
        const searchEmpty     = document.getElementById("search-empty")     as HTMLElement;

        let acSelectedIdx = -1;

        function setAcSelected(items: HTMLButtonElement[], idx: number) {
            items.forEach((btn, i) => {
                btn.classList.toggle("suggestion-active", i === idx);
                btn.setAttribute("aria-selected", String(i === idx));
            });
        }

        function hideAutocomplete() {
            autocomplete.classList.add("hidden");
            autocomplete.innerHTML = "";
            acSelectedIdx = -1;
        }

        function renderSuggestions(matches: string[]) {
            autocomplete.innerHTML = "";
            matches.forEach(band => {
                const li  = document.createElement("li");
                li.setAttribute("role", "option");
                li.setAttribute("aria-selected", "false");
                const btn = document.createElement("button");
                btn.type      = "button";
                btn.className = "search-suggestion font-bahnschrift";
                btn.textContent = band;
                btn.dataset.band = band;
                btn.addEventListener("click", () => activateSearch(band));
                li.appendChild(btn);
                autocomplete.appendChild(li);
            });
            autocomplete.classList.remove("hidden");
            acSelectedIdx = -1;
        }

        function activateSearch(bandName: string) {
            // Deactivate all category tabs
            tabs.forEach(b => b.classList.remove("tab-active"));
            sections.forEach(s => s.classList.add("hidden"));

            // Populate search grid — deduplicate by image src, prefer thumbs with date label
            searchGrid.innerHTML = "";
            const candidates = new Map<string, { thumb: HTMLElement; hasDate: boolean }>();

            document.querySelectorAll<HTMLElement>(".poster-thumb[data-bands]").forEach(thumb => {
                const img = thumb.querySelector("img");
                if (!img) return;
                const src = img.getAttribute("src") || "";
                if (!src) return;

                let bands: string[] = [];
                try { bands = JSON.parse(thumb.dataset.bands ?? "[]"); } catch {}
                if (!bands.some(b => b.toLowerCase() === bandName.toLowerCase())) return;

                // Prefer the clone that already carries a visible date/label span
                const hasDate = !!thumb.querySelector("span");
                const existing = candidates.get(src);
                if (!existing || (!existing.hasDate && hasDate)) {
                    candidates.set(src, { thumb, hasDate });
                }
            });

            const locationDisplay: Record<string, string> = {
                underground:  "Underground",
                georgiadis:   "Georgiadis Park",
                karabolas:    "Karabolas",
                voutes:       "Voutes",
                xenia:        "Xenia",
                evangelismos: "Evangelismos",
                walls:        "Walls",
            };

            let count = 0;
            candidates.forEach(({ thumb }) => {
                const clone    = thumb.cloneNode(true) as HTMLElement;
                const date     = clone.dataset.date     ?? "";
                const location = clone.dataset.location ?? "";

                // Strip any existing label spans — we'll add consistent fresh ones
                clone.querySelectorAll("span").forEach(s => s.remove());

                // Location label (appended first → visually on top via order-first)
                const locText = locationDisplay[location] ?? location;
                if (locText) {
                    const locSpan = document.createElement("span");
                    locSpan.className = "font-bahnschrift text-sm text-base-900/40 mb-1 uppercase tracking-wider text-center order-first";
                    locSpan.textContent = locText;
                    clone.appendChild(locSpan);
                }

                // Date label (appended second → visually below location)
                if (date) {
                    const [y, m, d] = date.split("-");
                    const dateSpan = document.createElement("span");
                    dateSpan.className = "font-bahnschrift text-sm text-base-900/40 mb-2 tracking-wider text-center order-first";
                    dateSpan.textContent = `${d}.${m}.${y}`;
                    clone.appendChild(dateSpan);
                }

                searchGrid.appendChild(clone);
                count++;
            });

            searchEmpty.classList.toggle("hidden", count > 0);
            searchGrid.classList.toggle("hidden", count === 0);
            searchSection.classList.remove("hidden");

            // Update category title watermark
            if (categoryTitle) {
                categoryTitle.textContent = bandName;
                categoryTitle.classList.remove("text-xl");
                categoryTitle.classList.add("text-3xl");
            }

            bandSearch.value = bandName;
            searchClear.classList.remove("hidden");
            hideAutocomplete();
        }

        function clearSearch() {
            bandSearch.value = "";
            searchClear.classList.add("hidden");
            hideAutocomplete();
            searchSection.classList.add("hidden");
            searchGrid.innerHTML = "";
            // Re-activate first tab
            const firstTab = document.querySelector<HTMLButtonElement>(".category-tab");
            if (firstTab) activateTab(firstTab);
        }

        bandSearch.addEventListener("input", () => {
            const q = bandSearch.value.trim();
            searchClear.classList.toggle("hidden", q === "");
            if (!q) { hideAutocomplete(); return; }
            const ql = q.toLowerCase();
            const prefix = allBands.filter(b => b.toLowerCase().startsWith(ql));
            const middle = allBands.filter(b => !b.toLowerCase().startsWith(ql) && b.toLowerCase().includes(ql));
            const matches = [...prefix, ...middle];
            if (matches.length === 0) { hideAutocomplete(); return; }
            renderSuggestions(matches.slice(0, 10));
        });

        bandSearch.addEventListener("keydown", (e) => {
            const items = Array.from(autocomplete.querySelectorAll<HTMLButtonElement>(".search-suggestion"));
            const open  = !autocomplete.classList.contains("hidden");

            if (e.key === "ArrowDown") {
                e.preventDefault();
                if (!open && bandSearch.value.trim()) {
                    const matches = allBands.filter(b => b.toLowerCase().startsWith(bandSearch.value.trim().toLowerCase()));
                    if (matches.length) renderSuggestions(matches.slice(0, 10));
                    return;
                }
                acSelectedIdx = Math.min(acSelectedIdx + 1, items.length - 1);
                setAcSelected(items, acSelectedIdx);
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                acSelectedIdx = Math.max(acSelectedIdx - 1, -1);
                setAcSelected(items, acSelectedIdx);
            } else if (e.key === "Enter") {
                e.preventDefault();
                if (open && acSelectedIdx >= 0 && items[acSelectedIdx]) {
                    activateSearch(items[acSelectedIdx].dataset.band!);
                } else {
                    const q = bandSearch.value.trim();
                    if (q) {
                        const exact = allBands.find(b => b.toLowerCase() === q.toLowerCase());
                        activateSearch(exact ?? q);
                    }
                }
            } else if (e.key === "Escape") {
                if (open) { hideAutocomplete(); }
                else { clearSearch(); }
            }
        });

        searchClear.addEventListener("click", clearSearch);

        // Close autocomplete when clicking outside
        document.addEventListener("click", (e) => {
            if (!(e.target as HTMLElement).closest("#search-container")) {
                hideAutocomplete();
            }
        });

        // Clicking a category tab also resets the search input
        tabs.forEach(btn => btn.addEventListener("click", () => {
            bandSearch.value = "";
            searchClear.classList.add("hidden");
            hideAutocomplete();
        }));
    </script>
</Layout>

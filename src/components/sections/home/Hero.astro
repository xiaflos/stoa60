---
// components
import Container from "../../elements/Container.astro"
import Text from "../../elements/Text.astro"
import Heading from "../../elements/Heading.astro"
import ImageContainer from "../../elements/ImageContainer.astro"
import Link from "../../elements/Link.astro"
import LanguageToggle from "../../elements/LanguageToggle.astro"

// assets
import stolensimadi from "../../../assets/images/posters/Upcoming/3.axeon_veil2.jpg";

// Gig calendar data (edit here to update)
interface Gig {
    monthKey: string;
    date: string;
    bands: string[];
}

const gigs: Gig[] = [
    { monthKey: "cal.april", date: "18", bands: ["Axeon", "Veil Omega"] },
    { monthKey: "cal.april", date: "25", bands: ["Junkheart", "Ποντικια"] },
    { monthKey: "cal.may",   date: "2",  bands: ["SOMA", "Malhotra"] },
    { monthKey: "cal.may",   date: "9",  bands: ["Tiffany", "Thymics"] },
    { monthKey: "cal.may",   date: "16", bands: ["ΚΑΘΑΡΟΣ ΧΑΛΚΟΣ", "ΑΡΚΟΥΔΕΣ ΤΩΝ ΑΓΩΓΩΝ ΤΗΣ ΠΟΛΥΚΑΤΟΙΚΙΑΣ"] },
    { monthKey: "cal.may",   date: "23", bands: ["State of Loss"] },
];

// Group by month
const gigsByMonth: { monthKey: string; gigs: Gig[] }[] = [];
for (const gig of gigs) {
    let group = gigsByMonth.find(m => m.monthKey === gig.monthKey);
    if (!group) { group = { monthKey: gig.monthKey, gigs: [] }; gigsByMonth.push(group); }
    group.gigs.push(gig);
}
---

<Container variant={"xl"} class="flex flex-col md:flex-row py-2 !gap-0 justify-between lg:h-[calc(100vh-5rem)] lg:max-h-[calc(100vh-5rem)]">

    <!-- Left column: Poster + newsletter -->
    <div class="md:w-1/2 flex items-center justify-center order-2 md:order-none">
        <div class="w-full max-w-[20.8rem] lg:max-w-[24.96rem] flex flex-col">
            <Heading tagName="h2" tagSize="h5" class="mb-2 text-center" data-i18n="hero.nextgig">next gig</Heading>
            <ImageContainer src={stolensimadi} alt="Upcoming gig poster" />

            <!-- Newsletter: below poster on all screen sizes -->
            <div class="w-full mt-4">
                <Text variant={'sm'} class="text-base-900 mb-2 font-grunge text-center" data-i18n="hero.newsletter">gig mail alert</Text>
                <form class="flex gap-2">
                    <input
                        type="email"
                        placeholder="your@email.com"
                        required
                        data-i18n-placeholder="hero.placeholder"
                        class="min-w-0 flex-1 px-4 py-2 border-2 border-base-900 bg-transparent text-base-900 font-mono placeholder:text-base-700 focus:outline-none focus:ring-2 focus:ring-base-900"
                    />
                    <button
                        type="submit"
                        class="px-4 py-2 bg-base-900 text-base-100 font-grunge text-xl hover:opacity-80 transition-opacity whitespace-nowrap"
                        data-i18n="hero.subscribe"
                    >
                        Subscribe
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right column -->
    <div class="md:w-1/2 flex flex-col order-1 md:order-none md:py-8 lg:h-full lg:min-h-0">

        <!-- Nav -->
        <nav class="flex flex-wrap gap-4 md:gap-8 justify-center md:justify-start items-center">
            <a href="/works" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.posters">Posters</a>
            <a href="/about" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.about">About</a>
            <LanguageToggle />
        </nav>

        <!-- Title + subtitles -->
        <div class="text-base-900 flex flex-col gap-1 items-center md:items-start text-center md:text-left mt-6 md:mt-16">
            <Text variant={'xl'} class="!text-[clamp(32pt,8vw,56pt)] mb-1" data-i18n="hero.title">STOA60</Text>
            <Text variant={'xl'} class="!text-[1.75rem] md:!text-40" data-i18n="hero.subtitle1">underground venue in Iraqlion,</Text>
            <Text variant={'xl'} class="!text-[1.75rem] md:!text-40" data-i18n="hero.subtitle2">10 years, few hundred gigs and counting.</Text>
        </div>

        <!-- Inline gig calendar -->
        <div class="flex-1 min-h-0 overflow-y-auto mt-6 md:mt-4 w-full scrollbar-none" role="region" aria-label="Upcoming gigs">
            {gigsByMonth.map(({ monthKey, gigs }) => (
                <div class="mb-4">
                    <!-- Month label -->
                    <div class="border-b border-base-900/30 mb-1 pb-0.5">
                        <span class="font-bahnschrift font-bold text-sm text-base-900/40 uppercase tracking-widest" data-i18n={monthKey}></span>
                    </div>
                    <!-- Gig rows -->
                    {gigs.map((gig) => (
                        <div class="flex items-baseline gap-3 py-1.5 border-b border-base-900/10">
                            <span class="font-bahnschrift font-bold text-2xl text-base-900/40 leading-none w-8 shrink-0">{gig.date}</span>
                            <span class="font-bahnschrift font-bold text-base text-base-900 uppercase leading-snug flex flex-wrap items-baseline gap-x-2">
                                {gig.bands.map((band, i) => (
                                    <>
                                        <span>{band}</span>
                                        {i < gig.bands.length - 1 && (
                                            <span class="text-base-900/50 font-black text-lg leading-none">×</span>
                                        )}
                                    </>
                                ))}
                            </span>
                        </div>
                    ))}
                </div>
            ))}
        </div>


    </div>

</Container>

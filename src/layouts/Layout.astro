---
// stylesheet
import "../styles/global.css";

// components
import BaseHead from "../components/global/BaseHead.astro";
import Wrapper from "../components/global/Wrapper.astro";
import Footer from "../components/global/Footer.astro";

// assets
import '@fontsource/road-rage';
import '@fontsource-variable/jetbrains-mono';
import bg from "../assets/images/bg.jpg";
import bgWide from "../assets/images/bgwide.jpg";
import { getImage } from "astro:assets";

// props
const { title, footerAlignRight = false, footerInnerClass = "", tileBgOnMobile = false, mobileBgWide = false, desktopNoScroll = false } = Astro.props;

const backgroundImage = await getImage({src: bg, format:'jpg'});
const wideBgImage = mobileBgWide ? await getImage({src: bgWide, format:'jpg'}) : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<BaseHead pageTitle={title}/>
	{mobileBgWide && wideBgImage && (
		<style set:html={`@media (max-width: 767px) { body { background-image: url(${wideBgImage.src}) !important; } }`}></style>
	)}
	<body style=`background-image: url(${backgroundImage.src})` class:list={["bg-cover bg-center bg-no-repeat bg-fixed max-md:!bg-scroll box-border", tileBgOnMobile && "max-md:!bg-auto max-md:!bg-repeat", desktopNoScroll && "md:overflow-hidden"]}>
		<!-- Background noise effect -->
		<div class="noise-[67,22,25] fixed inset-0 pointer-events-none"></div>
		<!-- Wrapper component to make sure all content on the website is above the noise filter background -->
		<Wrapper>
			<!-- Skip to content for keyboard navigation -->
			<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-base-100 focus:text-base-900 focus:px-4 focus:py-2 focus:font-mono">Skip to content</a>
			<main id="main-content" class="flex flex-col">
				<slot />
			</main>
			<Footer alignRight={footerAlignRight} innerClass={footerInnerClass} />
		</Wrapper>
	</body>
</html>



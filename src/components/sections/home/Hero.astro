---
// components
import Container from "../../elements/Container.astro"
import Text from "../../elements/Text.astro"
import Heading from "../../elements/Heading.astro"
import ImageContainer from "../../elements/ImageContainer.astro"
import Link from "../../elements/Link.astro"
import LanguageToggle from "../../elements/LanguageToggle.astro"

// assets
import stolensimadi from "../../../assets/images/posters/Upcoming/2.SUBATOMIC.jpg";
---

<Container variant={"xl"} class="flex flex-col md:flex-row py-2 !gap-0 justify-between lg:h-[calc(100vh-5rem)] lg:max-h-[calc(100vh-5rem)]">

    <!-- Left column: Poster — defines the row height -->
    <div class="md:w-1/2 flex items-center justify-center order-2 md:order-none">
        <div class="w-full max-w-[20.8rem] lg:max-w-[24.96rem]">
            <ImageContainer src={stolensimadi} alt="Upcoming gig poster" />
        </div>
    </div>

    <!-- Right column -->
    <div class="md:w-1/2 flex flex-col order-1 md:order-none md:py-8">

        <!-- Nav -->
        <nav class="flex flex-wrap gap-4 md:gap-8 justify-center md:justify-start items-center">
            <a href="/" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.home">Home</a>
            <a href="/works" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.posters">Posters</a>
            <a href="/about" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.about">About</a>
            <LanguageToggle />
        </nav>

        <!-- Title + subtitles -->
        <div class="text-base-900 flex flex-col gap-1 items-center md:items-start text-center md:text-left mt-6 md:mt-10">
            <Text variant={'xl'} class="!text-[clamp(32pt,8vw,56pt)] mb-1" data-i18n="hero.title">STOA60</Text>
            <Text variant={'xl'} class="!text-[1.75rem] md:!text-40" data-i18n="hero.subtitle1">underground venue in Iraqlion,</Text>
            <Text variant={'xl'} class="!text-[1.75rem] md:!text-40" data-i18n="hero.subtitle2">10 years, few hundred gigs and counting.</Text>
        </div>

        <!-- Next gig + newsletter -->
        <div class="flex flex-col gap-4 items-center md:items-start mt-10 md:mt-12">
            <div class="flex flex-col items-center md:items-start">
                <Heading tagName="h1" tagSize="h1" data-i18n="hero.nextgig">next gig</Heading>
                <Text class="text-base-900 !text-[32pt] font-grunge hidden md:block">&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;</Text>
            </div>

            <div class="w-full max-w-md">
                <Text variant={'sm'} class="text-base-900 mb-2 font-grunge" data-i18n="hero.newsletter">gig mail alert</Text>
                <form class="flex gap-2">
                    <input
                        type="email"
                        placeholder="your@email.com"
                        required
                        data-i18n-placeholder="hero.placeholder"
                        class="min-w-0 flex-1 px-4 py-2 border-2 border-base-900 bg-transparent text-base-900 font-mono placeholder:text-base-700 focus:outline-none focus:ring-2 focus:ring-base-900"
                    />
                    <button
                        type="submit"
                        class="px-4 py-2 bg-base-900 text-base-100 font-grunge text-xl hover:opacity-80 transition-opacity whitespace-nowrap"
                        data-i18n="hero.subscribe"
                    >
                        Subscribe
                    </button>
                </form>
            </div>
        </div>

    </div>

</Container>

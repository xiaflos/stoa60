---
// components
import Container from "../../elements/Container.astro"
import Text from "../../elements/Text.astro"
import Heading from "../../elements/Heading.astro"
import ImageContainer from "../../elements/ImageContainer.astro"
import LanguageToggle from "../../elements/LanguageToggle.astro"
import NewsletterForm from "../../elements/NewsletterForm.astro"

// assets
import stolensimadi from "../../../assets/images/posters/Upcoming/3.axeon_veil2.jpg";

// Gig calendar data (edit here to update)
interface Gig {
    monthKey: string;
    date: string;
    bands: string[];
}

const gigs: Gig[] = [
    { monthKey: "cal.april", date: "18", bands: ["Axeon", "Veil Omega"] },
    { monthKey: "cal.april", date: "25", bands: ["Junkheart", "Ποντικια"] },
    { monthKey: "cal.may",   date: "2",  bands: ["SOMA", "Malhotra"] },
    { monthKey: "cal.may",   date: "9",  bands: ["Tiffany", "Thymics"] },
    { monthKey: "cal.may",   date: "16", bands: ["ΚΑΘΑΡΟΣ ΧΑΛΚΟΣ", "ΑΡΚΟΥΔΕΣ ΤΩΝ ΑΓΩΓΩΝ ΤΗΣ ΠΟΛΥΚΑΤΟΙΚΙΑΣ"] },
    { monthKey: "cal.may",   date: "23", bands: ["State of Loss", "TBA"] },
];

// Default (Greek) month labels for SSR — overridden by JS i18n on client
const monthLabels: Record<string, string> = {
    "cal.april": "Απρίλιος",
    "cal.may":   "Μάιος",
};

// Max gigs shown on homepage — add more to the array freely, only this many will render
const MAX_GIGS = 8;
const visibleGigs = gigs.slice(0, MAX_GIGS);

// Group by month
const gigsByMonth: { monthKey: string; gigs: Gig[] }[] = [];
for (const gig of visibleGigs) {
    let group = gigsByMonth.find(m => m.monthKey === gig.monthKey);
    if (!group) { group = { monthKey: gig.monthKey, gigs: [] }; gigsByMonth.push(group); }
    group.gigs.push(gig);
}
---

<Container variant={"xl"} class="grid md:grid-cols-2 py-2 !gap-0 md:h-[calc(100vh-5rem)] md:max-h-[calc(100vh-5rem)] md:overflow-hidden md:[grid-template-rows:auto_1fr]">

    <!-- 1. Title + nav + subtitles (mobile: top / desktop: right col top) -->
    <div class="md:col-start-2 md:row-start-1 flex flex-col md:pt-5 md:pb-8">

        <!-- STOA60 + Nav: stacked on mobile, inline on desktop -->
        <div class="flex flex-col md:flex-row md:flex-wrap md:gap-8 md:items-baseline md:justify-start text-base-900 md:mt-5 lg:mt-7 items-center gap-1">
            <Text variant={'xl'} class="!text-[clamp(40pt,9vw,80pt)] !leading-none" data-i18n="hero.title">STOA60</Text>
            <nav class="flex flex-wrap gap-4 md:gap-8 items-center">
                <a href="/works" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.posters">Posters</a>
                <a href="/about" class="text-base-900 font-grunge text-2xl md:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.about">About</a>
                <LanguageToggle />
            </nav>
        </div>

        <!-- Subtitles -->
        <div class="text-base-900 flex flex-col gap-1 items-center md:items-start text-center md:text-left mt-4">
            <Text variant={'xl'} class="!text-base md:!text-lg !font-bahnschrift font-bold uppercase" data-i18n="hero.subtitle1">DIY underground venue in Iraqlion,</Text>
            <Text variant={'xl'} class="!text-base md:!text-lg !font-bahnschrift font-bold uppercase" data-i18n="hero.subtitle2">10 years, few hundred gigs and counting.</Text>
        </div>

    </div>

    <!-- 2. Poster + newsletter (mobile: middle / desktop: left col spanning both rows) -->
    <div class="md:col-start-1 md:row-start-1 md:row-span-2 flex items-start justify-center mt-6 md:mt-0 md:pt-8">
        <div class="w-full max-w-[17rem] lg:max-w-[21rem] flex flex-col">
            <Heading tagName="h2" tagSize="h5" class="mb-2 text-center" data-i18n="hero.nextgig">next gig</Heading>
            <button id="hero-poster-btn" class="w-full cursor-pointer hover:opacity-80 transition-opacity" aria-label="View poster fullscreen">
                <ImageContainer src={stolensimadi} alt="Upcoming gig poster" />
            </button>

            <!-- Newsletter: below poster on desktop only -->
            <div class="hidden md:block mt-4">
                <NewsletterForm />
            </div>
        </div>
    </div>

    <!-- 3. Calendar (mobile: below poster / desktop: right col bottom) -->
    <div class="md:col-start-2 md:row-start-2 overflow-y-auto mt-6 md:mt-0 scrollbar-none md:min-h-0 [mask-image:linear-gradient(to_bottom,black_70%,transparent_100%)] md:[mask-image:linear-gradient(to_bottom,black_70%,transparent_100%)] flex flex-col items-center md:items-start" role="region" aria-label="Upcoming gigs">
        {gigsByMonth.map(({ monthKey, gigs }) => (
            <div class="mb-4 w-full max-w-xs md:max-w-none">
                <!-- Month label -->
                <div class="border-b border-base-900/30 mb-1 pb-0.5">
                    <span class="font-bahnschrift font-bold text-sm text-base-900/40 uppercase tracking-widest" data-i18n={monthKey}>{monthLabels[monthKey]}</span>
                </div>
                <!-- Gig rows -->
                {gigs.map((gig) => (
                    <div class="flex items-baseline gap-3 py-1.5 border-b border-base-900/10">
                        <span class="font-bahnschrift font-bold text-2xl text-base-900/40 leading-none w-8 shrink-0">{gig.date}</span>
                        <span class="font-bahnschrift font-bold text-base text-base-900 uppercase leading-snug flex flex-wrap items-baseline gap-x-2">
                            {gig.bands.map((band, i) => (
                                <>
                                    <span>{band}</span>
                                    {i < gig.bands.length - 1 && (
                                        <span class="text-base-900/50 font-black text-lg leading-none">×</span>
                                    )}
                                </>
                            ))}
                        </span>
                    </div>
                ))}
            </div>
        ))}
    </div>

    <!-- Newsletter: mobile only, shown at bottom -->
    <div class="md:hidden mt-6">
        <NewsletterForm />
    </div>

</Container>

<!-- Lightbox -->
<div id="hero-lightbox" class="fixed inset-0 bg-black/90 z-50 items-center justify-center" style="display:none">
    <button id="hero-lightbox-close" class="absolute top-4 right-4 text-white text-4xl font-grunge hover:opacity-70 z-10">&times;</button>
    <img id="hero-lightbox-img" src="" alt="Poster fullscreen" class="max-h-[90vh] max-w-[85vw] object-contain" />
</div>

<script>
    const btn       = document.getElementById("hero-poster-btn")!;
    const lightbox  = document.getElementById("hero-lightbox") as HTMLElement;
    const img       = document.getElementById("hero-lightbox-img") as HTMLImageElement;
    const closeBtn  = document.getElementById("hero-lightbox-close")!;

    function open() {
        const src = btn.querySelector("img")?.currentSrc || btn.querySelector("img")?.getAttribute("src") || "";
        img.src = src;
        lightbox.style.display = "flex";
    }
    function close() { lightbox.style.display = "none"; }

    btn.addEventListener("click", open);
    closeBtn.addEventListener("click", close);
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); });
    window.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
</script>

---
// components
import Container from "../../elements/Container.astro"
import Text from "../../elements/Text.astro"
import Heading from "../../elements/Heading.astro"
import ImageContainer from "../../elements/ImageContainer.astro"
import LanguageToggle from "../../elements/LanguageToggle.astro"
import NewsletterForm from "../../elements/NewsletterForm.astro"

// assets
import stolensimadi from "../../../assets/images/posters/Upcoming/2026-04-25_junkheart_pontikia.jpg";

// Gig calendar data (edit here to update)
interface Band {
    name: string;
    url?: string;
    tba?: boolean;
}

interface Gig {
    monthKey: string;
    date: string;
    bands: Band[];
}

const gigs: Gig[] = [
    { monthKey: "cal.april", date: "25", bands: [
        { name: "Junkheart", url: "https://junkheart.bandcamp.com/music" },
        { name: "Ποντικια",  url: "https://www.1431am.org/artist/pontikia/" },
    ]},
    { monthKey: "cal.may",   date: "2",  bands: [
        { name: "SOMA",     url: "https://somamesoma.bandcamp.com/music" },
        { name: "Malhotra", url: "https://malhotra.bandcamp.com/album/ruler-sun" },
    ]},
    { monthKey: "cal.may",   date: "16", bands: [
        { name: "ΚΑΘΑΡΟΣ ΧΑΛΚΟΣ",                         url: "https://katharoschalkos.bandcamp.com/album/-" },
        { name: "ΑΡΚΟΥΔΕΣ ΤΩΝ ΑΓΩΓΩΝ ΤΗΣ ΠΟΛΥΚΑΤΟΙΚΙΑΣ", url: "https://www.youtube.com/watch?v=aArwHqZA-7Y" },
    ]},
    { monthKey: "cal.september", date: "19", bands: [
        { name: "AFK", url: "https://aarghfuckkill.bandcamp.com/" },
        { name: "TBA", tba: true },
    ]},
];

// Default (Greek) month labels for SSR — overridden by JS i18n on client
const monthLabels: Record<string, string> = {
    "cal.april":     "Απρίλιος",
    "cal.may":       "Μάιος",
    "cal.september": "Σεπτεμβριος",
};

// Max gigs shown on homepage — add more to the array freely, only this many will render
const MAX_GIGS = 8;
const visibleGigs = gigs.slice(0, MAX_GIGS);

// Group by month
const gigsByMonth: { monthKey: string; gigs: Gig[] }[] = [];
for (const gig of visibleGigs) {
    let group = gigsByMonth.find(m => m.monthKey === gig.monthKey);
    if (!group) { group = { monthKey: gig.monthKey, gigs: [] }; gigsByMonth.push(group); }
    group.gigs.push(gig);
}
---

<Container variant={"xl"} class="grid grid-cols-1 min-[850px]:grid-cols-[minmax(0,38rem)_minmax(0,40rem)] min-[850px]:justify-center py-2 !gap-0 min-[850px]:!gap-x-20 min-[850px]:!gap-y-0 overflow-x-hidden min-[850px]:min-h-[calc(100vh-5rem)] min-[850px]:[grid-template-rows:auto_1fr]">

    <!-- 1. Title + nav + subtitles (mobile: top / desktop: right col top) -->
    <div class="min-[850px]:col-start-2 min-[850px]:row-start-1 flex flex-col min-[850px]:pt-5 min-[850px]:pb-3 min-w-0">

        <!-- STOA60 + Nav: stacked on mobile, inline on desktop -->
        <div class="flex flex-col min-[850px]:flex-row min-[850px]:flex-wrap min-[850px]:gap-8 min-[850px]:items-baseline min-[850px]:justify-start text-base-900 min-[850px]:mt-7 items-center gap-1">
            <Text variant={'xl'} class="!text-[clamp(40pt,9vw,80pt)] !leading-none" data-i18n="hero.title">STOA60</Text>
            <nav class="flex flex-wrap gap-4 min-[850px]:gap-8 items-center">
                <a href="/posters" class="text-base-900 font-grunge text-2xl min-[850px]:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.posters">Posters</a>
                <a href="/about" class="text-base-900 font-grunge text-2xl min-[850px]:text-3xl underline underline-offset-4 decoration-2 hover:text-base-700" data-i18n="nav.about">About</a>
                <LanguageToggle />
            </nav>
        </div>

        <!-- Subtitles -->
        <div class="text-base-900 flex flex-col gap-1 items-center min-[850px]:items-start text-center min-[850px]:text-left mt-4">
            <Text variant={'xl'} class="!text-base min-[850px]:!text-lg !font-bahnschrift font-bold uppercase" data-i18n="hero.subtitle1">υπόγειος συναυλιακός χώρος στο Ηράκλειο,</Text>
            <Text variant={'xl'} class="!text-base min-[850px]:!text-lg !font-bahnschrift font-bold uppercase" data-i18n="hero.subtitle2">Στηρίζουμε το κουτί. Σεβόμαστε τη γειτονιά.</Text>
            <Text variant={'xl'} class="!text-base min-[850px]:!text-lg !font-bahnschrift font-bold uppercase" data-i18n="hero.subtitle3">2015-2026.</Text>
        </div>

    </div>

    <!-- 2. Poster + newsletter (mobile: middle / desktop: left col spanning both rows) -->
    <div class="min-[850px]:col-start-1 min-[850px]:row-start-1 min-[850px]:row-span-2 flex items-start justify-center min-[850px]:justify-end mt-6 min-[850px]:mt-0 min-[850px]:pt-12 min-w-0 min-[850px]:min-h-0 min-[850px]:h-full min-[850px]:pb-2">
        <div class="w-full max-w-[19rem] min-[850px]:w-[22rem] min-[850px]:max-w-none min-[850px]:shrink-0 flex flex-col min-[850px]:min-h-0 min-[850px]:h-full">
            <!-- "next gig" above poster frame — mobile only -->
            <span class="min-[850px]:hidden block text-center font-grunge text-base-900 text-xl tracking-widest uppercase mb-2 select-none" data-i18n="hero.nextgig">next gig</span>
            <div class="flex items-start gap-1 min-[850px]:flex-1 min-[850px]:min-h-0 min-[850px]:items-stretch min-[850px]:mt-4">
                <!-- "next gig" rotated vertically on the left — desktop only -->
                <div class="hidden min-[850px]:flex items-start justify-center shrink-0 self-stretch">
                    <span class="font-grunge text-base-900 text-xl tracking-widest uppercase [writing-mode:vertical-rl] rotate-180 select-none" data-i18n="hero.nextgig">next gig</span>
                </div>
                <!-- Poster + desktop newsletter aligned together.
                     Button and newsletter are direct siblings so the gap between
                     them is always a fixed mt-4 — no flex-grow wrapper that would
                     expand with available space and push them apart. -->
                <div class="flex-1 flex flex-col min-w-0 min-[850px]:min-h-0 min-[850px]:items-center">
                    <button
                        id="hero-poster-btn"
                        class="cursor-pointer hover:opacity-80 transition-opacity w-full shrink-0"
                        aria-label="View poster fullscreen">
                        <ImageContainer src={stolensimadi} alt="Upcoming gig poster" />
                    </button>
                    <!-- Newsletter: below poster on desktop only — fixed gap -->
                    <div class="hidden min-[850px]:block w-full shrink-0 min-[850px]:mt-6">
                        <NewsletterForm />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Calendar (mobile: below poster / desktop: right col bottom) -->
    <div class="min-[850px]:col-start-2 min-[850px]:row-start-2 overflow-y-auto overflow-x-hidden mt-6 min-[850px]:mt-0 scrollbar-none min-[850px]:min-h-0 [mask-image:linear-gradient(to_bottom,black_70%,transparent_100%)] min-[850px]:[mask-image:linear-gradient(to_bottom,black_70%,transparent_100%)] flex flex-col items-center min-[850px]:items-start min-w-0" role="region" aria-label="Upcoming gigs">
        {gigsByMonth.map(({ monthKey, gigs }) => (
            <div class="mb-4 w-full max-w-xs min-[850px]:max-w-none">
                <!-- Month label -->
                <div class="border-b border-base-900/30 mb-1 pb-0.5">
                    <span class="font-bahnschrift font-bold text-sm text-base-900/40 uppercase tracking-widest" data-i18n={monthKey}>{monthLabels[monthKey]}</span>
                </div>
                <!-- Gig rows -->
                {gigs.map((gig) => (
                    <div class="flex items-baseline gap-3 py-1.5 border-b border-base-900/10">
                        <span class="font-bahnschrift font-bold text-2xl text-base-900/40 leading-none w-8 shrink-0">{gig.date}</span>
                        <span class="font-bahnschrift font-bold text-base text-base-900 uppercase leading-snug flex flex-wrap items-baseline gap-x-2">
                            {gig.bands.map((band, i) => (
                                <>
                                    {band.tba ? (
                                        <span class="text-sm font-normal text-base-900/40 tracking-widest">{band.name}</span>
                                    ) : band.url ? (
                                        <a href={band.url} target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-2">{band.name}</a>
                                    ) : (
                                        <span>{band.name}</span>
                                    )}
                                    {i < gig.bands.length - 1 && (
                                        <span class="text-base-900/50 font-black text-lg leading-none">×</span>
                                    )}
                                </>
                            ))}
                        </span>
                    </div>
                ))}
            </div>
        ))}
    </div>


    <!-- Newsletter: mobile only, shown at bottom -->
    <div class="min-[850px]:hidden mt-6 mb-16 min-w-0 flex justify-center">
        <div class="w-full max-w-[19rem]">
            <NewsletterForm />
        </div>
    </div>

</Container>

<!-- Lightbox -->
<div id="hero-lightbox" class="fixed inset-0 bg-black/90 z-50 items-center justify-center" style="display:none" role="dialog" aria-modal="true" aria-label="Poster fullscreen view">
    <button id="hero-lightbox-close" class="absolute top-4 right-4 text-white text-4xl font-grunge hover:opacity-70 z-10" aria-label="Close lightbox">&times;</button>
    <img id="hero-lightbox-img" src="" alt="Poster fullscreen" class="max-h-[90vh] max-w-[85vw] object-contain" />
</div>

<style is:global>
    /* Soft white glow around the poster — gives it presence on the dark
       background without bringing back a hard frame. Applied on both
       mobile and desktop. */
    #hero-poster-btn img {
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.18),
            0 2px 18px rgba(255, 255, 255, 0.22),
            0 10px 60px rgba(255, 255, 255, 0.3),
            0 0 120px rgba(255, 255, 255, 0.18);
        transition: box-shadow 0.3s ease;
    }
    #hero-poster-btn:hover img {
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.28),
            0 2px 24px rgba(255, 255, 255, 0.3),
            0 12px 70px rgba(255, 255, 255, 0.4),
            0 0 150px rgba(255, 255, 255, 0.28);
    }
</style>

<script>
    const btn       = document.getElementById("hero-poster-btn")!;
    const lightbox  = document.getElementById("hero-lightbox") as HTMLElement;
    const img       = document.getElementById("hero-lightbox-img") as HTMLImageElement;
    const closeBtn  = document.getElementById("hero-lightbox-close")!;

    function open() {
        const src = btn.querySelector("img")?.currentSrc || btn.querySelector("img")?.getAttribute("src") || "";
        img.src = src;
        lightbox.style.display = "flex";
        closeBtn.focus();
    }
    function close() {
        lightbox.style.display = "none";
        btn.focus();
    }

    btn.addEventListener("click", open);
    closeBtn.addEventListener("click", close);
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); });
    window.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
</script>

---
const { pageTitle } = Astro.props;
const siteUrl = "https://stoa60.net";
const thumbnail = `${siteUrl}/og-image.jpg`;
const description = "STOA60 - Underground gigspace in Iraklion, Crete. 10+ years, hundreds of gigs.";
---
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content={description}>
	<meta name="generator" content={Astro.generator} />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="robots" content="index, follow" />
	<meta name="googlebot" content="index, follow" />

	<!-- Open Graph -->
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content="STOA60" />
	<meta property="og:title" content={`Stoa60 - ${pageTitle}`} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={thumbnail} />
	<meta property="og:image:width" content="1200" />
	<meta property="og:image:height" content="630" />
	<meta property="og:image:type" content="image/jpeg" />
	<meta property="og:url" content={siteUrl} />

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={`Stoa60 - ${pageTitle}`} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={thumbnail} />

	<link rel="icon" href="/favicon.ico" sizes="any" />
	<link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="apple-touch-icon" href="/favicon.png" />
	<title>Stoa60 - {pageTitle}</title>
</head>

